DATABASE_URL="mysql://medcof:medcof@localhost:3306/medcof"
PORT=3000
NODE_ENV=development
JWT_SECRET="change-me-in-production-min-32-chars-long!!"
JWT_EXPIRES_IN_SECONDS=86400
BCRYPT_ROUNDS=12

# Comma-separated allowed origins, or * for reflect-any-origin (dev only). Required in production.
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Trust X-Forwarded-* when behind a reverse proxy (true / false / 1 / 0)
# TRUST_PROXY=false

# Max JSON request body size (Express limit string)
# JSON_BODY_LIMIT=512kb

# Global rate limit per IP (excludes /health)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=300

# Stricter rate limit for POST /auth/login (anti brute-force)
# LOGIN_RATE_LIMIT_WINDOW_MS=900000
# LOGIN_RATE_LIMIT_MAX=10
