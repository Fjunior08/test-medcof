# Copy to ".env" in the repo root to override docker compose defaults.

JWT_SECRET=change-me-use-at-least-32-characters-long-secret

MYSQL_ROOT_PASSWORD=medcof_root_dev_only
MYSQL_DATABASE=medcof
MYSQL_USER=medcof
MYSQL_PASSWORD=medcof_app_dev_only
